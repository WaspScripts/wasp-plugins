const
  WL_PLUGINS_VERSION_YEAR: Integer = 2026;
  WL_PLUGINS_VERSION_MONTH: Integer = 05;
  WL_PLUGINS_VERSION_DAY: Integer = 09;
  WL_PLUGINS_VERSION_COMMIT_HASH: String = 'e228fb6';

  WASPLIB_PLUGINS_VERSION: String := ToStr(WL_PLUGINS_VERSION_YEAR) + '.' +
                             PadL(ToStr(WL_PLUGINS_VERSION_MONTH), 2, '0') + '.' +
                             PadL(ToStr(WL_PLUGINS_VERSION_DAY), 2, '0') + '-' +
                             WL_PLUGINS_VERSION_COMMIT_HASH;
